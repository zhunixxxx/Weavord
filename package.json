{
  "name": "weavord",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "bash scripts/dev.sh",
    "start": "bash scripts/dev.sh",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "build:all": "npm run build:server && npm run build",
    "lint": "npm run lint --prefix client",
    "preview": "npm run preview --prefix client",
    "install:all": "npm install --prefix client && npm install --prefix server",
    "rebuild:native": "npm rebuild better-sqlite3 --prefix server"
  }
}
